__pycache__/
*.pyc
*.log
output/
output*/
# checkpoints/ and data/ are local symlinks to machine-specific mounts (contents come from
# HuggingFace); anchor without a trailing slash so the symlinks themselves are ignored too.
/checkpoints
/data
*.ckpt
*.ply
*.npz
*.zip

# Keep only the small bundled demo inputs in git: point clouds (sample/*.ply) and one
# conditioning image per shape (sample_imgs/*.png). The large precomputed implicit samples
# ship via HuggingFace (implicit_test.zip), not git.
!sample/
!sample/*.ply
!sample_imgs/
!sample_imgs/*.png
